# Copy to .env and fill in. .env is gitignored; .env.example is committed.

# PostgreSQL connection string — used by the app and the migration runner.
# Matches the local docker-compose service below.
DATABASE_URL=postgresql://cloudcampus:cloudcampus@localhost:5432/cloudcampus

# Set to "true" when connecting to Amazon RDS (rds.force_ssl = 1).
# Leave "false" for local Docker Postgres.
DATABASE_SSL=false

# Set to "true" to authenticate to RDS via IAM (no DB password in DATABASE_URL).
# Leave unset/"false" for local Docker Postgres and for password auth.
# DATABASE_IAM_AUTH=true
# DATABASE_REGION=ap-southeast-1

# Secret used to sign session JWTs.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-with-a-long-random-string

# Amazon S3 — binary asset storage (member photos, covers, resources).
# In production, credentials come from the IAM role attached to Amplify
# compute — leave S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY unset. Set them
# locally only for MinIO (docker compose) or a developer IAM user.
#
# For local MinIO (docker compose): set S3_ENDPOINT=http://localhost:9000,
# S3_REGION=us-east-1 (any value works), S3_ACCESS_KEY_ID/SECRET to the
# MINIO_ROOT_USER/MINIO_ROOT_PASSWORD from docker-compose.yml, and create
# the bucket once (mc alias / console) before uploading.
S3_BUCKET=cloudcampus-aws-s3
S3_REGION=ap-southeast-1
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY_ID=replace-with-an-access-key-id
# S3_SECRET_ACCESS_KEY=replace-with-a-secret-access-key

# Gmail SMTP for password reset / registration decision / email change.
# Use an App Password (https://myaccount.google.com/apppasswords), not the
# Google account password. Leave unset to log mail to stdout in dev.
# smtp_email=cloudcampus@example.com
# smtp_pass=xxxx xxxx xxxx xxxx

# Origin used to build absolute links inside emails (reset, email-change…).
APP_ORIGIN=http://localhost:3000
